<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="EnglishWord.QuizPage"
             Title="Quiz">

    <VerticalStackLayout Padding="24" Spacing="20">

        <Label Text="What is the definition of:"
               FontSize="16"
               TextColor="Gray" />

        <Label x:Name="QuizWordLabel"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <core:SfTextInputLayout Hint="Your answer" ContainerType="Outlined">
            <Entry x:Name="AnswerEntry" />
        </core:SfTextInputLayout>

        <Button Text="Check Answer"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="8"
                Clicked="OnCheckClicked" />

        <Frame x:Name="ResultFrame"
               IsVisible="False"
               CornerRadius="8"
               Padding="16"
               BorderColor="Transparent">
            <Label x:Name="ResultLabel"
                   FontSize="16"
                   HorizontalOptions="Center" />
        </Frame>

        <Button Text="Next Word"
                BackgroundColor="#6c757d"
                TextColor="White"
                CornerRadius="8"
                Clicked="OnNextClicked" />

    </VerticalStackLayout>

</ContentPage>
