<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="EnglishWord.AddWordPage"
             Title="Add Word">

    <VerticalStackLayout Padding="24" Spacing="16">

        <core:SfTextInputLayout Hint="Word" ContainerType="Outlined">
            <Entry x:Name="WordEntry" />
        </core:SfTextInputLayout>

        <core:SfTextInputLayout Hint="Definition" ContainerType="Outlined">
            <Editor x:Name="DefinitionEntry" AutoSize="TextChanges" />
        </core:SfTextInputLayout>

        <core:SfTextInputLayout Hint="Part of Speech (e.g. Noun, Verb, Adjective)" ContainerType="Outlined">
            <Entry x:Name="PartOfSpeechEntry" />
        </core:SfTextInputLayout>

        <Button Text="Save Word"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="8"
                Clicked="OnSaveClicked" />

    </VerticalStackLayout>

</ContentPage>
