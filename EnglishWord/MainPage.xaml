<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:listView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
             x:Class="EnglishWord.MainPage"
             Title="English Words">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">

        <inputLayout:SfTextInputLayout Grid.Row="0"
                                       Hint="Search word..."
                                       ContainerType="Outlined"
                                       ContainerBackground="Transparent">
            <Entry x:Name="SearchEntry" TextChanged="OnSearchTextChanged" />
        </inputLayout:SfTextInputLayout>

        <listView:SfListView Grid.Row="1"
                             x:Name="WordListView"
                             ItemsSource="{Binding Words}"
                             ItemSize="70"
                             SelectionMode="Single"
                             SelectionChanged="OnWordSelected">
            <listView:SfListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="{Binding Word}"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding Definition}"
                                   FontSize="13"
                                   TextColor="Gray" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="{Binding PartOfSpeech}"
                               FontSize="12"
                               TextColor="White"
                               BackgroundColor="#512BD4"
                               Padding="6,2"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </listView:SfListView.ItemTemplate>
        </listView:SfListView>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0" Text="+ Add Word"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnAddWordClicked" />
            <Button Grid.Column="1" Text="Quiz Me"
                    BackgroundColor="#6c757d"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnQuizClicked" />
        </Grid>

    </Grid>

</ContentPage>
